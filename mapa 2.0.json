{
  "title": "Mapa do Viajante - Landing Page Completa",
  "type": "page",
  "version": "0.4",
  "page_settings": {
    "template": "elementor_canvas",
    "hide_title": "yes",
    "custom_css": "@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=League+Spartan:wght@400;500;600;700&display=swap');\n\n:root {\n  --primary: #F58E26;\n  --primary-hover: #D67618;\n  --coffee: #3D3426;\n  --cream: #FBF8F4;\n  --sand: #F5EDE3;\n}\n\nbody {\n  font-family: 'Inter', sans-serif;\n  color: var(--coffee);\n}\n\nh1, h2, h3, h4, h5, h6 {\n  font-family: 'League Spartan', sans-serif;\n}\n\n.btn-primary {\n  background: var(--primary);\n  color: white;\n  padding: 16px 32px;\n  border-radius: 10px;\n  font-weight: 700;\n  transition: all 0.3s ease;\n}\n\n.btn-primary:hover {\n  background: var(--primary-hover);\n  transform: translateY(-2px);\n}\n\n.elementor-accordion .elementor-accordion-item {\n  margin-bottom: 12px;\n  border-radius: 12px !important;\n  overflow: hidden;\n}\n\n.elementor-accordion .elementor-tab-title {\n  background: var(--sand) !important;\n  border-radius: 12px !important;\n}\n\n.elementor-accordion .elementor-tab-content {\n  background: var(--sand) !important;\n}"
  },
  "content": [
    {
      "id": "header-section",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "padding": {
          "unit": "px",
          "top": "12",
          "right": "20",
          "bottom": "12",
          "left": "20"
        },
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "position": "fixed",
        "z_index": 100,
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": {
          "horizontal": 0,
          "vertical": 2,
          "blur": 10,
          "spread": 0,
          "color": "rgba(0,0,0,0.05)"
        }
      },
      "elements": [
        {
          "id": "header-container",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "flex_direction": "row",
            "flex_justify_content": "space-between",
            "flex_align_items": "center"
          },
          "elements": [
            {
              "id": "logo-container",
              "elType": "container",
              "settings": {
                "flex_direction": "row",
                "flex_align_items": "center",
                "flex_gap": {
                  "unit": "px",
                  "size": 8
                }
              },
              "elements": [
                {
                  "id": "logo-icon",
                  "elType": "widget",
                  "widgetType": "icon",
                  "settings": {
                    "selected_icon": {
                      "value": "fas fa-map-marker-alt",
                      "library": "fa-solid"
                    },
                    "primary_color": "#FFFFFF",
                    "icon_padding": {
                      "unit": "px",
                      "size": 8
                    },
                    "background_color": "#F58E26",
                    "border_radius": {
                      "unit": "px",
                      "size": 8
                    }
                  }
                },
                {
                  "id": "logo-text",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "O Segredo do Viajante",
                    "header_size": "h6",
                    "title_color": "#3D3426",
                    "typography_typography": "custom",
                    "typography_font_family": "League Spartan",
                    "typography_font_weight": "700",
                    "typography_font_size": {
                      "unit": "px",
                      "size": 18
                    }
                  }
                }
              ]
            },
            {
              "id": "header-cta",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Quero Acesso",
                "link": {
                  "url": "#pricing"
                },
                "background_color": "#F58E26",
                "button_text_color": "#FFFFFF",
                "border_radius": {
                  "unit": "px",
                  "size": 8
                },
                "typography_typography": "custom",
                "typography_font_family": "Inter",
                "typography_font_weight": "600",
                "typography_font_size": {
                  "unit": "px",
                  "size": 14
                },
                "button_padding": {
                  "unit": "px",
                  "top": "10",
                  "right": "20",
                  "bottom": "10",
                  "left": "20"
                },
                "hover_color": "#FFFFFF",
                "button_background_hover_color": "#D67618"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "hero-section",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "min_height": {
          "unit": "vh",
          "size": 90
        },
        "padding": {
          "unit": "px",
          "top": "100",
          "right": "20",
          "bottom": "60",
          "left": "20"
        },
        "background_background": "gradient",
        "background_color": "#FBF8F4",
        "background_color_b": "#F5EDE3",
        "background_gradient_angle": {
          "unit": "deg",
          "size": 180
        }
      },
      "elements": [
        {
          "id": "hero-container",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "flex_direction": "row",
            "flex_direction_tablet": "column-reverse",
            "flex_gap": {
              "unit": "px",
              "size": 40
            },
            "flex_align_items": "center"
          },
          "elements": [
            {
              "id": "hero-text",
              "elType": "container",
              "settings": {
                "flex_direction": "column",
                "width": {
                  "unit": "%",
                  "size": 50
                },
                "width_tablet": {
                  "unit": "%",
                  "size": 100
                }
              },
              "elements": [
                {
                  "id": "hero-headline",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "Todas as ferramentas que você precisa planejar sua viagem em muito menos tempo e com mais economia - <span style=\"color: #F58E26;\">tudo em só lugar!</span>",
                    "header_size": "h1",
                    "title_color": "#3D3426",
                    "typography_typography": "custom",
                    "typography_font_family": "League Spartan",
                    "typography_font_weight": "700",
                    "typography_font_size": {
                      "unit": "px",
                      "size": 48
                    },
                    "typography_font_size_tablet": {
                      "unit": "px",
                      "size": 36
                    },
                    "typography_font_size_mobile": {
                      "unit": "px",
                      "size": 28
                    },
                    "typography_line_height": {
                      "unit": "em",
                      "size": 1.1
                    }
                  }
                },
                {
                  "id": "hero-subtitle",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "editor": "<p style=\"font-size: 18px; color: rgba(61, 52, 38, 0.7); font-family: 'Inter', sans-serif;\">10 anos viajando o mundo condensados em um sistema inteligente com IA que organiza tudo em um único lugar</p>"
                  }
                },
                {
                  "id": "hero-cta-button",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "text": "QUERO ACESSO AGORA",
                    "link": {
                      "url": "#pricing"
                    },
                    "align": "left",
                    "align_tablet": "center",
                    "background_color": "#F58E26",
                    "button_text_color": "#FFFFFF",
                    "border_radius": {
                      "unit": "px",
                      "size": 10
                    },
                    "typography_typography": "custom",
                    "typography_font_family": "Inter",
                    "typography_font_weight": "700",
                    "typography_font_size": {
                      "unit": "px",
                      "size": 16
                    },
                    "button_padding": {
                      "unit": "px",
                      "top": "16",
                      "right": "32",
                      "bottom": "16",
                      "left": "32"
                    },
                    "hover_color": "#FFFFFF",
                    "button_background_hover_color": "#D67618"
                  }
                },
                {
                  "id": "hero-trust-badges",
                  "elType": "container",
                  "settings": {
                    "flex_direction": "row",
                    "flex_gap": {
                      "unit": "px",
                      "size": 16
                    },
                    "margin": {
                      "unit": "px",
                      "top": "16"
                    }
                  },
                  "elements": [
                    {
                      "id": "trust-rating",
                      "elType": "widget",
                      "widgetType": "icon-list",
                      "settings": {
                        "icon_list": [
                          {
                            "text": "Avaliação 4.9/5",
                            "selected_icon": {
                              "value": "fas fa-star",
                              "library": "fa-solid"
                            }
                          }
                        ],
                        "icon_color": "#F58E26",
                        "text_color": "rgba(61, 52, 38, 0.6)",
                        "typography_typography": "custom",
                        "typography_font_family": "Inter",
                        "typography_font_size": {
                          "unit": "px",
                          "size": 14
                        }
                      }
                    },
                    {
                      "id": "trust-guarantee",
                      "elType": "widget",
                      "widgetType": "icon-list",
                      "settings": {
                        "icon_list": [
                          {
                            "text": "Garantia de 15 dias",
                            "selected_icon": {
                              "value": "fas fa-shield-alt",
                              "library": "fa-solid"
                            }
                          }
                        ],
                        "icon_color": "#F58E26",
                        "text_color": "rgba(61, 52, 38, 0.6)",
                        "typography_typography": "custom",
                        "typography_font_family": "Inter",
                        "typography_font_size": {
                          "unit": "px",
                          "size": 14
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "hero-image",
              "elType": "container",
              "settings": {
                "width": {
                  "unit": "%",
                  "size": 50
                },
                "width_tablet": {
                  "unit": "%",
                  "size": 100
                }
              },
              "elements": [
                {
                  "id": "hero-mockup",
                  "elType": "widget",
                  "widgetType": "image",
                  "settings": {
                    "image": {
                      "url": "{{UPLOAD_URL}}/hero-mockup-devices.png",
                      "alt": "Mapa do Viajante - Desktop, Tablet e Mobile"
                    },
                    "image_size": "full",
                    "align": "center"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
